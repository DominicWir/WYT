<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#000000">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ Settings \u0026 Debug"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Step Count Display -->
    <TextView
        android:id="@+id/step_count"
        android:layout_width="match_parent"
        android:layout_height="185dp"
        android:layout_marginBottom="24dp"
        android:background="#333333"
        android:gravity="center"
        android:padding="16dp"
        android:text="Steps\nTotal: 0\nSession: 0"
        android:textColor="#FFFFFF"
        android:textSize="36sp" />

    <!-- Device State -->
    <TextView
        android:id="@+id/device_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DETECTING..."
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Threshold Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A666666"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎚️ Threshold Controls"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/threshold_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Threshold: 1.50 m/s²"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/decrease_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="−"
                android:textSize="24sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#FF5722"/>

            <Button
                android:id="@+id/reset_steps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset Steps"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#FF9800"/>

            <Button
                android:id="@+id/increase_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+"
                android:textSize="24sp"
                android:layout_marginStart="4dp"
                android:backgroundTint="#4CAF50"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ML Activity Debug Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A4CAF50"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 ML Model Activity"
            android:textSize="16sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/ml_buffer_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buffer: 0/50 samples"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/ml_activity_prediction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity: Unknown (0%)"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/ml_threshold_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Threshold: 1.50 m/s²"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/ml_last_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last update: Never"
            android:textSize="12sp"
            android:textColor="#888888"/>
    </LinearLayout>

    <!-- WiFi RSSI Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A2196F3"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📶 WiFi RSSI Monitor"
            android:textSize="16sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/wifi_ap_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Access Points: 0"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/wifi_variance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Variance: 0.0 dBm²"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/wifi_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Scanning..."
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/wifi_strongest_ap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Strongest: None"
            android:textSize="12sp"
            android:textColor="#888888"/>
    </LinearLayout>

    <!-- Continuous Learning Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1AFFC107"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧠 Continuous Learning"
            android:textSize="16sp"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/retraining_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next retraining in: 50 steps"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ProgressBar
            android:id="@+id/retraining_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="50"
            android:progress="0"
            android:progressTint="#FFC107"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/retraining_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Collected: 0 samples | Accuracy: --"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/retraining_last_run"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last retraining: Never"
            android:textSize="12sp"
            android:textColor="#888888"/>
    </LinearLayout>

    <!-- Particle Filter Position Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A4CAF50"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Particle Filter Position"
            android:textSize="16sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/position_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Initializing..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/position_coordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Position: Not initialized"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/position_heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heading: --°"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/position_confidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confidence: --"
            android:textSize="12sp"
            android:textColor="#CCCCCC"/>
    </LinearLayout>

    <!-- Particle Filter Testing Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A2196F3"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 Particle Filter Testing"
            android:textSize="16sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_start_pf_test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Accuracy Test"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_pf_test_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ready"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_pf_mean_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mean Error: --"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_pf_debug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PF Status: --"
            android:textSize="12sp"
            android:textColor="#888888"/>
    </LinearLayout>

    <!-- Calibration Button -->
    <Button
        android:id="@+id/calibrate_button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Calibrate Step Detection"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#9C27B0"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Walk normally. Adjust threshold if steps aren't detected."
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

</LinearLayout>

</ScrollView>
