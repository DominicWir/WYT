<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Indoor Positioning and Reminder App"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Step Count Display -->
        <TextView
            android:id="@+id/tvStepCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Steps: 0"
            android:textSize="20sp"/>

        <TextView
            android:id="@+id/tvSessionSteps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session: 0"
            android:textSize="18sp"
            android:layout_marginTop="4dp"/>

        <!-- State Display -->
        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="State: UNKNOWN"
            android:textSize="18sp"
            android:layout_marginTop="16dp"/>

        <!-- Step Length Display -->
        <TextView
            android:id="@+id/tvStepLength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step Length: 0.00m"
            android:textSize="18sp"
            android:layout_marginTop="4dp"/>

        <!-- Threshold Control -->
        <TextView
            android:id="@+id/tvThresholdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Threshold: 1.20 m/s²"
            android:textSize="18sp"
            android:layout_marginTop="24dp"/>

        <SeekBar
            android:id="@+id/seekBarThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <!-- Magnetic Localization Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--- Magnetic Localization ---"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Position: Not estimated yet"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvCalibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calibration: None"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvMagnetic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Magnetic Field: ---"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <!-- Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnResetSteps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset All Steps"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnStartGraph"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="View Graph"/>

        </LinearLayout>

        <!-- Instructions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instructions:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Walk naturally with phone in hand\n2. First 10 steps estimate initial position\n3. Adjust threshold if step detection is off\n4. Reset steps when changing test scenarios"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>